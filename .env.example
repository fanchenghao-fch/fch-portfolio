# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your-anon-key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-service-role-key
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-anon-key

# QQ SMTP (Nodemailer)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-qq@qq.com
SMTP_PASS=your-smtp-auth-code
ALERT_EMAIL=your-email@qq.com

# Session
SESSION_SECRET=your-random-secret-string

# Admin
ADMIN_EMAIL=your-admin@email.com
