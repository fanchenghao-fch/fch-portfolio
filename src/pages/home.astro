---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import HeroArt from "../components/HeroArt.astro";
import CapabilityCards from "../components/CapabilityCards.astro";
import Timeline from "../components/Timeline.astro";
import ProjectCard from "../components/ProjectCard.astro";
import HonorsSkills from "../components/HonorsSkills.astro";
import Footer from "../components/Footer.astro";
import FAB from "../components/FAB.astro";
import { getProjectsByCompany } from "../data/projects";
import { profileContent } from "../data/profile";
import type { Lang } from "../lib/i18n";

const lang = (Astro.locals?.lang ?? "zh") as Lang;
const t = profileContent[lang];

// Sort projects based on visitor's company (light customization)
const company = Astro.locals?.company ?? "";
const sortedProjects = getProjectsByCompany(company);
---

<BaseLayout title={lang === "zh" ? "范诚昊 · 懂城市的 AI 产品经理" : "Fan Chenghao · AI PM Who Understands Cities"}>
  <Nav />

  <!-- HERO -->
  <header class="hero">
    <div>
      <h1 class="h-hero">
        {t.hero.line1}<br />
        <span class="accent">{t.hero.accent}</span>
      </h1>
      <p class="hero-sub">{t.hero.subtitle}</p>
      <div class="hero-cta">
        <a href="#projects" class="btn btn-primary">{t.hero.viewWork}</a>
        <a href="/rag" class="btn btn-ghost">{t.hero.askAvatar}</a>
      </div>
    </div>
    <div class="hero-art">
      <HeroArt />
    </div>
  </header>

  <!-- CAPABILITY -->
  <section class="section" id="capability">
    <div class="reveal">
      <div class="eyebrow">{lang === "zh" ? "能力画像" : "Capability Profile"}</div>
      <h2 class="h2">{lang === "zh" ? "AI 产品 × 城乡规划，<br>两个引擎同时转。" : "AI Product × Urban Planning,<br>two engines running together."}</h2>
    </div>
    <CapabilityCards />
  </section>

  <!-- EXPERIENCE (dark) -->
  <section class="dark">
    <div class="section" id="experience">
      <div class="reveal">
        <div class="eyebrow">{lang === "zh" ? "经历" : "Experience"}</div>
        <h2 class="h2">{lang === "zh" ? "从规划院走向产品。" : "From planning to products."}</h2>
      </div>
      <Timeline />
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="section" id="projects">
    <div class="reveal">
      <div class="eyebrow">{lang === "zh" ? "作品" : "Projects"}</div>
      <h2 class="h2">{lang === "zh" ? "8 个项目，<br>横跨 AI 与城市。" : "8 projects,<br>spanning AI and cities."}</h2>
      {
        !company && (
          <p class="lead">{lang === "zh" ? "以下排序基于默认顺序。来访时填写公司名可自动定制排序。" : "Default ordering. Fill in your company at the gate for customized sorting."}</p>
        )
      }
    </div>
    <div class="proj-grid">
      {sortedProjects.map((project) => (
        <ProjectCard project={project} lang={lang} />
      ))}
    </div>
  </section>

  <!-- HONORS & SKILLS -->
  <HonorsSkills />

  <!-- FOOTER -->
  <Footer />

  <!-- FLOATING ACTION BUTTON -->
  <FAB />
</BaseLayout>

<script>
  const io = new IntersectionObserver(
    (es) => {
      es.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("in");
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 },
  );
  document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
</script>

<style>
  /* hero */
  .hero {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(48px, 8vw, 92px) 22px clamp(40px, 7vw, 80px);
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 40px;
    align-items: center;
  }
  .h-hero {
    font-size: clamp(42px, 7.2vw, 86px);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.0;
  }
  .h-hero .accent {
    color: var(--teal);
  }
  .hero-sub {
    font-size: clamp(17px, 2.1vw, 21px);
    color: var(--muted);
    margin-top: 24px;
    max-width: 460px;
    line-height: 1.5;
  }
  .hero-cta {
    display: flex;
    gap: 14px;
    margin-top: 34px;
    flex-wrap: wrap;
  }
  .hero-art {
    position: relative;
    width: 100%;
    aspect-ratio: 1/1;
  }
  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero-art {
      order: -1;
      max-width: 340px;
      margin: 0 auto;
    }
  }

  /* projects */
  .proj-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 54px;
  }
  @media (max-width: 720px) {
    .proj-grid {
      grid-template-columns: 1fr;
    }
  }

</style>
