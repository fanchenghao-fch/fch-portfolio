---
// English home page — delegates to the same components with lang="en"
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import HeroArt from "../../components/HeroArt.astro";
import CapabilityCards from "../../components/CapabilityCards.astro";
import Timeline from "../../components/Timeline.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import HonorsSkills from "../../components/HonorsSkills.astro";
import Footer from "../../components/Footer.astro";
import FAB from "../../components/FAB.astro";
import { getProjectsByCompany } from "../../data/projects";
import { profileContent } from "../../data/profile";

const company = Astro.locals?.company ?? "";
const sortedProjects = getProjectsByCompany(company);
const t = profileContent.en;
---

<BaseLayout title="Fan Chenghao · AI PM Who Understands Cities" lang="en">
  <Nav href="/en/home" />

  <!-- HERO -->
  <header class="hero">
    <div>
      <h1 class="h-hero">
        {t.hero.line1}<br />
        <span class="accent">{t.hero.accent}</span>
      </h1>
      <p class="hero-sub">{t.hero.subtitle}</p>
      <div class="hero-cta">
        <a href="#projects" class="btn btn-primary">{t.hero.viewWork}</a>
        <a href="/en/rag" class="btn btn-ghost">{t.hero.askAvatar}</a>
      </div>
    </div>
    <div class="hero-art">
      <HeroArt />
    </div>
  </header>

  <section class="section" id="capability">
    <div class="reveal">
      <div class="eyebrow">Capability Profile</div>
      <h2 class="h2">AI Product × Urban Planning,<br />two engines running together.</h2>
    </div>
    <CapabilityCards />
  </section>

  <section class="dark">
    <div class="section" id="experience">
      <div class="reveal">
        <div class="eyebrow">Experience</div>
        <h2 class="h2">From planning to products.</h2>
      </div>
      <Timeline />
    </div>
  </section>

  <section class="section" id="projects">
    <div class="reveal">
      <div class="eyebrow">Projects</div>
      <h2 class="h2">8 projects,<br />spanning AI and cities.</h2>
    </div>
    <div class="proj-grid">
      {sortedProjects.map((project) => (
        <ProjectCard project={project} lang="en" />
      ))}
    </div>
  </section>

  <HonorsSkills />
  <Footer />
  <FAB />
</BaseLayout>

<script>
  const io = new IntersectionObserver(
    (es) => {
      es.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("in");
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 },
  );
  document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
</script>

<style>
  .hero {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(48px, 8vw, 92px) 22px clamp(40px, 7vw, 80px);
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 40px;
    align-items: center;
  }
  .h-hero {
    font-size: clamp(42px, 7.2vw, 86px);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.0;
  }
  .h-hero .accent {
    color: var(--teal);
  }
  .hero-sub {
    font-size: clamp(17px, 2.1vw, 21px);
    color: var(--muted);
    margin-top: 24px;
    max-width: 460px;
    line-height: 1.5;
  }
  .hero-cta {
    display: flex;
    gap: 14px;
    margin-top: 34px;
    flex-wrap: wrap;
  }
  .hero-art {
    position: relative;
    width: 100%;
    aspect-ratio: 1/1;
  }
  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero-art {
      order: -1;
      max-width: 340px;
      margin: 0 auto;
    }
  }
  .proj-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 54px;
  }
  @media (max-width: 720px) {
    .proj-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
