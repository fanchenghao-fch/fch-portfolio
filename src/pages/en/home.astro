---
// English home page — delegates to the same components with lang="en"
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import HeroArt from "../../components/HeroArt.astro";
import CapabilityCards from "../../components/CapabilityCards.astro";
import Timeline from "../../components/Timeline.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import HonorsSkills from "../../components/HonorsSkills.astro";
import Footer from "../../components/Footer.astro";
import FAB from "../../components/FAB.astro";
import { getProjectsByCompany } from "../../data/projects";
import { profileContent } from "../../data/profile";

const company = Astro.locals?.company ?? "";
const sortedProjects = getProjectsByCompany(company);
const t = profileContent.en;
---

<BaseLayout title="Fan Chenghao · AI PM Who Understands Cities" lang="en">
  <Nav href="/en/home" />

  <!-- HERO -->
  <header class="hero">
    <div>
      <h1 class="h-hero">
        {t.hero.line1}<br />
        <span class="accent">{t.hero.accent}</span>
      </h1>
      <p class="hero-sub">{t.hero.subtitle}</p>
      <div class="hero-cta">
        <a href="#projects" class="btn btn-primary">{t.hero.viewWork}</a>
        <a href="/en/rag" class="btn btn-ghost">{t.hero.askAvatar}</a>
      </div>
    </div>
    <div class="hero-art">
      <HeroArt />
    </div>
  </header>

  <section class="section" id="capability">
    <div class="reveal">
      <div class="eyebrow">Capability Profile</div>
      <h2 class="h2">Creativity × Logic × Practice × Collaboration</h2>
    </div>
    <CapabilityCards />
  </section>

  <section class="dark">
    <div class="section" id="experience">
      <div class="reveal">
        <div class="eyebrow">Experience</div>
        <h2 class="h2">From planning to products.</h2>
      </div>
      <Timeline />
    </div>
  </section>

  <section class="section" id="projects">
    <div class="reveal">
      <div class="eyebrow">Projects</div>
      <h2 class="h2">8 projects,<br />spanning AI and cities.</h2>
    </div>
    <div class="hwrap reveal">
      <div class="hhint">
        <svg viewBox="0 0 24 24" fill="none" stroke="#6E6E73" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
        Swipe or drag to browse all 8 projects
      </div>
      <div class="htrack" id="htrack">
        {sortedProjects.map((project, i) => (
          <ProjectCard project={project} lang="en" index={i + 1} />
        ))}
      </div>
      <div class="hnav">
        <button class="hbtn" id="hprev" aria-label="Previous">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1D1D1F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"/></svg>
        </button>
        <button class="hbtn" id="hnext" aria-label="Next">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1D1D1F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
        </button>
      </div>
    </div>
  </section>

  <HonorsSkills />
  <Footer />
  <FAB />
</BaseLayout>

<script>
  const io = new IntersectionObserver(
    (es) => {
      es.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("in");
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 },
  );
  document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
</script>
<script>
  (function () {
    var tr = document.getElementById("htrack");
    if (!tr) return;
    var prev = document.getElementById("hprev"),
      next = document.getElementById("hnext");
    function step() {
      var c = tr.querySelector(".hcard");
      return c ? c.getBoundingClientRect().width + 20 : 340;
    }
    function upd() {
      if (!prev || !next) return;
      prev.disabled = tr.scrollLeft < 8;
      next.disabled = tr.scrollLeft + tr.clientWidth >= tr.scrollWidth - 8;
    }
    if (prev)
      prev.addEventListener("click", function () {
        tr.scrollBy({ left: -step(), behavior: "smooth" });
      });
    if (next)
      next.addEventListener("click", function () {
        tr.scrollBy({ left: step(), behavior: "smooth" });
      });
    tr.addEventListener("scroll", upd);
    window.addEventListener("resize", upd);
    upd();
  })();
</script>

<style>
  .hero {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(48px, 8vw, 92px) 22px clamp(40px, 7vw, 80px);
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 40px;
    align-items: center;
  }
  .h-hero {
    font-size: clamp(42px, 7.2vw, 86px);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.0;
  }
  .h-hero .accent {
    color: var(--teal);
  }
  .hero-sub {
    font-size: clamp(17px, 2.1vw, 21px);
    color: var(--muted);
    margin-top: 24px;
    max-width: 460px;
    line-height: 1.5;
  }
  .hero-cta {
    display: flex;
    gap: 14px;
    margin-top: 34px;
    flex-wrap: wrap;
  }
  .hero-art {
    position: relative;
    width: 100%;
    aspect-ratio: 1/1;
  }
  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero-art {
      order: -1;
      max-width: 340px;
      margin: 0 auto;
    }
  }
  .hwrap {
    position: relative;
    margin-top: 40px;
  }
  .hhint {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 18px;
  }
  .hhint svg {
    width: 17px;
    height: 17px;
  }
  .htrack {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 22px;
    padding: 6px 22px 24px;
    margin: 0 -22px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(14, 140, 130, 0.4) transparent;
  }
  .htrack::-webkit-scrollbar {
    height: 8px;
  }
  .htrack::-webkit-scrollbar-track {
    background: transparent;
  }
  .htrack::-webkit-scrollbar-thumb {
    background: rgba(14, 140, 130, 0.35);
    border-radius: 980px;
  }
  .hnav {
    display: flex;
    gap: 10px;
    margin-top: 18px;
  }
  .hbtn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: 0.2s;
  }
  .hbtn:hover:not(:disabled) {
    background: var(--paper);
    border-color: rgba(14, 140, 130, 0.4);
  }
  .hbtn svg {
    width: 18px;
    height: 18px;
  }
  .hbtn:disabled {
    opacity: 0.35;
    cursor: default;
  }
  @media (prefers-reduced-motion: reduce) {
    .hcard,
    .hcard-art svg,
    .hcard-art::after {
      transition: none;
    }
  }
</style>
