---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { Lang } from "../lib/i18n";

const lang = (Astro.locals?.lang ?? "zh") as Lang;
const zh = {
  title: "数字分身 · 范诚昊",
  subtitle: "基于真实经历作答 · 带引用",
  welcome: "你好，我是范诚昊的数字分身。关于他的 AI 项目、城市规划经历、技能与作品，都可以直接问我。",
  suggestLabel: "你可以这样问",
  placeholder: "问问关于范诚昊的任何事…",
  disclaimer: "仅基于真实语料作答，不编造 · 与职业无关的问题会礼貌婉拒",
  close: "关闭",
  suggestions: [
    "他做过哪些 AI 项目？",
    "他的城市规划背景，怎么帮到做产品？",
    "他自用的 AI 工具库有哪些？",
    "他在此芯科技具体做了什么？",
  ],
};
const en = {
  title: "Digital Twin · Fan Chenghao",
  subtitle: "Answers based on real experience · with citations",
  welcome: "Hi, I'm Fan Chenghao's digital twin. Ask me anything about his AI projects, urban planning experience, skills, and work.",
  suggestLabel: "Try asking",
  placeholder: "Ask anything about Fan Chenghao...",
  disclaimer: "Based on real data only, no fabrication · Unrelated questions will be politely declined",
  close: "Close",
  suggestions: [
    "What AI projects has he built?",
    "How does his urban planning background help in product management?",
    "What AI tools does he use?",
    "What did he do at CIX Technology?",
  ],
};
const t = lang === "zh" ? zh : en;
---

<BaseLayout title={t.title}>
  <div class="shell">
    <div class="panel">
      <!-- Header -->
      <div class="head">
        <div class="av">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="6" cy="6" r="2.4" fill="#0E8C82" />
            <circle cx="18" cy="9" r="2.4" fill="#0E8C82" />
            <circle cx="10" cy="18" r="2.4" fill="#0E8C82" />
            <line x1="6" y1="6" x2="18" y2="9" stroke="#0E8C82" stroke-width="1.4" />
            <line x1="18" y1="9" x2="10" y2="18" stroke="#0E8C82" stroke-width="1.4" />
          </svg>
        </div>
        <div class="t">
          <div class="n">{t.title}</div>
          <div class="s">{t.subtitle}</div>
        </div>
        <a href="/home" class="x" aria-label={t.close}>
          <svg viewBox="0 0 24 24" fill="none" stroke="#1D1D1F" stroke-width="2">
            <line x1="6" y1="6" x2="18" y2="18" /><line x1="18" y1="6" x2="6" y2="18" />
          </svg>
        </a>
      </div>

      <!-- Thread -->
      <div class="thread" id="thread">
        <div class="welcome" id="welcome">{t.welcome}</div>

        <div class="suggest" id="suggest">
          <div class="lbl">{t.suggestLabel}</div>
          <div class="chips">
            {t.suggestions.map((s) => (
              <button class="chip" data-question={s}>{s}</button>
            ))}
          </div>
        </div>
      </div>

      <!-- Composer -->
      <div class="composer">
        <div class="box">
          <textarea
            id="input"
            rows="1"
            placeholder={t.placeholder}
            autofocus
          ></textarea>
          <button class="send" id="send-btn" aria-label="Send">
            <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="19" x2="12" y2="5" /><polyline points="6 11 12 5 18 11" />
            </svg>
          </button>
        </div>
        <div class="disc">{t.disclaimer}</div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const thread = document.getElementById("thread")!;
  const input = document.getElementById("input") as HTMLTextAreaElement;
  const sendBtn = document.getElementById("send-btn")!;

  let history: { role: "user" | "assistant"; content: string }[] = [];

  function hideSuggest() {
    document.getElementById("welcome")?.remove();
    document.getElementById("suggest")?.remove();
  }

  function addMe(text: string) {
    const d = document.createElement("div");
    d.className = "msg me";
    d.innerHTML = '<div class="bubble"></div>';
    d.querySelector(".bubble")!.textContent = text;
    thread.appendChild(d);
    thread.scrollTop = thread.scrollHeight;
  }

  function addBot(answer: string, cited?: string[]) {
    const d = document.createElement("div");
    d.className = "msg bot";
    d.innerHTML = `<div class="bubble">${answer.replace(/\n/g, "<br>")}</div>`;
    if (cited && cited.length > 0) {
      const citeStr = cited.join("、");
      const citeLabel = document.documentElement.lang === "en" ? "Cited" : "引用";
      d.innerHTML += `<span class="cite">▸ ${citeLabel}：${citeStr}</span>`;
    }
    thread.appendChild(d);
    thread.scrollTop = thread.scrollHeight;
  }

  function setLoading(loading: boolean) {
    sendBtn.disabled = loading;
    input.disabled = loading;
    if (loading) {
      const d = document.createElement("div");
      d.className = "msg bot";
      d.id = "loading-msg";
      d.innerHTML = '<div class="bubble" style="color:var(--muted)">...</div>';
      thread.appendChild(d);
      thread.scrollTop = thread.scrollHeight;
    } else {
      document.getElementById("loading-msg")?.remove();
    }
  }

  async function ask(question: string) {
    hideSuggest();
    addMe(question);
    history.push({ role: "user", content: question });
    setLoading(true);

    try {
      const resp = await fetch("/api/rag", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ question, history: history.slice(-6) }),
      });

      setLoading(false);
      const data = await resp.json();

      if (resp.ok && data.answer) {
        addBot(data.answer, data.citedProjects);
        history.push({ role: "assistant", content: data.answer });
      } else {
        addBot(data.error || "抱歉，暂时无法回答。请稍后再试。");
      }
    } catch {
      setLoading(false);
      addBot("网络错误，请稍后再试。");
    }
  }

  function send() {
    const v = input.value.trim();
    if (!v) return;
    input.value = "";
    grow(input);
    ask(v);
  }

  function grow(el: HTMLTextAreaElement) {
    el.style.height = "auto";
    el.style.height = Math.min(el.scrollHeight, 120) + "px";
  }

  // Event listeners
  sendBtn.addEventListener("click", send);
  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      send();
    }
  });
  input.addEventListener("input", () => grow(input));

  // Suggestion chips
  document.querySelectorAll(".chip").forEach((chip) => {
    chip.addEventListener("click", () => {
      const q = (chip as HTMLElement).dataset.question;
      if (q) ask(q);
    });
  });
</script>

<style>
  .shell {
    display: flex;
    justify-content: flex-end;
    min-height: 100vh;
    background: rgba(20, 24, 26, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .panel {
    width: 100%;
    max-width: 460px;
    background: var(--white);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    box-shadow: -20px 0 60px rgba(0, 0, 0, 0.18);
    animation: slide 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes slide {
    from {
      transform: translateX(40px);
      opacity: 0.4;
    }
    to {
      transform: none;
      opacity: 1;
    }
  }
  .head {
    padding: 18px 22px;
    border-bottom: 1px solid var(--line);
    display: flex;
    align-items: center;
    gap: 13px;
  }
  .av {
    width: 42px;
    height: 42px;
    border-radius: 13px;
    background: var(--teal-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .av svg {
    width: 24px;
    height: 24px;
  }
  .head .t {
    flex: 1;
  }
  .head .t .n {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .head .t .s {
    font-size: 12.5px;
    color: var(--muted);
    margin-top: 2px;
  }
  .head .x {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: 0.2s;
  }
  .head .x:hover {
    background: var(--paper);
  }
  .head .x svg {
    width: 15px;
    height: 15px;
  }
  .thread {
    flex: 1;
    overflow-y: auto;
    padding: 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .welcome {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.6;
  }
  .welcome b {
    color: var(--ink);
    font-weight: 600;
  }
  .suggest .lbl {
    font-size: 12px;
    color: #9a9aa0;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 6px 0 12px;
  }
  .chips {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .chip {
    text-align: left;
    font-size: 14.5px;
    color: #333;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 13px 16px;
    cursor: pointer;
    transition: 0.2s;
    font-family: inherit;
    line-height: 1.4;
  }
  .chip:hover {
    border-color: var(--teal);
    background: #fff;
    color: var(--teal-deep);
  }
  .msg {
    display: flex;
    flex-direction: column;
    max-width: 86%;
  }
  .msg.me {
    align-self: flex-end;
    align-items: flex-end;
  }
  .bubble {
    font-size: 15px;
    line-height: 1.6;
    padding: 12px 16px;
    border-radius: 18px;
    word-break: break-word;
  }
  .me .bubble {
    background: var(--teal);
    color: #fff;
    border-bottom-right-radius: 6px;
  }
  .bot .bubble {
    background: var(--paper);
    color: var(--ink);
    border: 1px solid var(--line);
    border-bottom-left-radius: 6px;
  }
  .cite {
    font-size: 12px;
    color: var(--teal-deep);
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .composer {
    padding: 14px 18px 20px;
    border-top: 1px solid var(--line);
  }
  .box {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 8px 8px 8px 16px;
    background: #fff;
    transition: 0.2s;
  }
  .box:focus-within {
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(14, 140, 130, 0.12);
  }
  .box textarea {
    flex: 1;
    border: none;
    outline: none;
    resize: none;
    font-family: inherit;
    font-size: 15px;
    line-height: 1.5;
    max-height: 120px;
    color: var(--ink);
    background: transparent;
    padding: 7px 0;
  }
  .send {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: none;
    background: var(--teal);
    cursor: pointer;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 0.2s;
  }
  .send:hover {
    background: var(--teal-deep);
  }
  .send:disabled {
    background: #c9d6d4;
    cursor: not-allowed;
  }
  .send svg {
    width: 18px;
    height: 18px;
  }
  .disc {
    font-size: 11.5px;
    color: #a9a9af;
    text-align: center;
    margin-top: 11px;
    line-height: 1.5;
  }
</style>
