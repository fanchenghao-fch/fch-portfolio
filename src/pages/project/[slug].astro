---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProjectBySlug } from "../../data/projects";
import type { Lang } from "../../lib/i18n";

const { slug } = Astro.params;
const project = getProjectBySlug(slug!);

if (!project) {
  return Astro.redirect("/home");
}

const lang = (Astro.locals?.lang ?? "zh") as Lang;
const title = lang === "zh" ? project.title : project.titleEn;
const role = lang === "zh" ? project.role : project.roleEn;
const tags = project.tags;
const overview = lang === "zh" ? project.detailOverview : project.detailOverviewEn;
const work = lang === "zh" ? project.detailWork : project.detailWorkEn;
const outcome = lang === "zh" ? project.detailOutcome : project.detailOutcomeEn;
const links = project.links;
const backText = lang === "zh" ? "返回作品集" : "Back to Portfolio";
---

<BaseLayout title={`${title} · 范诚昊`}>
  <div class="backdrop">
    <div class="modal">
      <a href="/home#projects" class="close" aria-label={lang === "zh" ? "关闭" : "Close"}>
        <svg viewBox="0 0 24 24" fill="none" stroke="#1D1D1F" stroke-width="2">
          <line x1="6" y1="6" x2="18" y2="18" /><line x1="18" y1="6" x2="6" y2="18" />
        </svg>
      </a>

      <div class="m-art">
        <svg viewBox="0 0 600 240" width="100%" height="100%" preserveAspectRatio="xMidYMid slice">
          <rect width="600" height="240" fill="#eaf2f0" />
          <g stroke="rgba(14,140,130,0.18)" stroke-width="1">
            <line x1="150" y1="0" x2="150" y2="240" /><line x1="300" y1="0" x2="300" y2="240" /><line x1="450" y1="0" x2="450" y2="240" />
            <line x1="0" y1="80" x2="600" y2="80" /><line x1="0" y1="160" x2="600" y2="160" />
          </g>
          <g>
            <circle cx="150" cy="80" r="7" fill="#0E8C82" /><circle cx="300" cy="160" r="9" fill="#0E8C82" />
            <circle cx="450" cy="80" r="7" fill="#0E8C82" /><circle cx="300" cy="80" r="5" fill="#0E8C82" opacity=".6" />
          </g>
          <g stroke="#0E8C82" stroke-width="1.6" opacity=".55">
            <line x1="150" y1="80" x2="300" y2="160" /><line x1="300" y1="160" x2="450" y2="80" />
            <line x1="300" y1="160" x2="300" y2="80" />
          </g>
        </svg>
      </div>

      <div class="m-body">
        <div>
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
        <h1 class="m-title">{title}</h1>

        <div class="meta">
          <div><div class="k">{lang === "zh" ? "我的角色" : "My Role"}</div><div class="v">{role}</div></div>
          <div><div class="k">{lang === "zh" ? "时间" : "Period"}</div><div class="v">{project.period}</div></div>
        </div>

        <div class="block">
          <h3>{lang === "zh" ? "项目概述" : "Overview"}</h3>
          <p>{overview}</p>
        </div>

        <div class="block">
          <h3>{lang === "zh" ? "我的工作" : "My Work"}</h3>
          <ul>
            {work.map((w) => <li>{w}</li>)}
          </ul>
        </div>

        <div class="block">
          <h3>{lang === "zh" ? "产出成果" : "Outcome"}</h3>
          <p>{outcome}</p>
          {
            project.images.length > 0 && (
              <div class="gallery">
                {project.images.map((img) => (
                  <div class="shot">
                    <img src={img} alt="" loading="lazy" />
                  </div>
                ))}
              </div>
            )
          }
        </div>

        <div class="links">
          {links.map((link) => (
            <a href={link.url} class="lk lk-primary">{lang === "zh" ? (link.label) : (link.labelEn || link.label)}</a>
          ))}
          <a href="/home#projects" class="lk lk-ghost">{backText}</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .modal {
    position: relative;
    width: 100%;
    max-width: 780px;
    background: var(--white);
    border-radius: 26px;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.3);
    animation: rise 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .close {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 5;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: 0.2s;
  }
  .close:hover {
    background: #fff;
    transform: scale(1.05);
  }
  .close svg {
    width: 16px;
    height: 16px;
  }
  .m-art {
    height: 240px;
    background: #eaf2f0;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .m-body {
    padding: 38px 44px 44px;
  }
  .m-title {
    font-size: clamp(26px, 4vw, 36px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 18px 0 0;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    margin-top: 24px;
    padding-bottom: 26px;
    border-bottom: 1px solid var(--line);
  }
  .meta .k {
    font-size: 12px;
    color: #9a9aa0;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .meta .v {
    font-size: 15px;
    color: var(--ink);
    margin-top: 6px;
    font-weight: 500;
  }
  .block {
    margin-top: 32px;
  }
  .block h3 {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal-deep);
    margin-bottom: 14px;
  }
  .block p {
    font-size: 16px;
    line-height: 1.7;
    color: #333;
  }
  .block ul {
    list-style: none;
    margin-top: 6px;
  }
  .block li {
    font-size: 16px;
    line-height: 1.7;
    color: #333;
    padding-left: 22px;
    position: relative;
  }
  .block li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 11px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal);
  }
  .gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 6px;
  }
  .shot {
    aspect-ratio: 4/3;
    background: #eef3f2;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #a9b8b5;
    font-size: 12px;
    border: 1px solid var(--line);
    overflow: hidden;
  }
  .shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 34px;
  }
  .lk {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 46px;
    padding: 0 22px;
    border-radius: 980px;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: 0.25s;
  }
  .lk-primary {
    background: var(--teal);
    color: #fff;
  }
  .lk-primary:hover {
    background: var(--teal-deep);
  }
  .lk-ghost {
    border: 1px solid var(--line);
    color: var(--ink);
  }
  .lk-ghost:hover {
    background: var(--paper);
  }
  @media (max-width: 640px) {
    .m-body {
      padding: 30px 24px 34px;
    }
    .gallery {
      grid-template-columns: repeat(2, 1fr);
    }
    .m-art {
      height: 180px;
    }
  }
</style>
