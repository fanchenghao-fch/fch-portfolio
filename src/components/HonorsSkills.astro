---
import type { Lang } from "../lib/i18n";
import { profileContent } from "../data/profile";

const lang = (Astro.locals?.lang ?? "zh") as Lang;
const { honors, skills } = profileContent[lang];
---

<!-- Skills -->
<section class="section" style="padding-top:0;">
  <div class="reveal">
    <div class="eyebrow">{lang === "zh" ? "技能" : "Skills"}</div>
    <h2 class="h2">{lang === "zh" ? "叽里咕噜地学了很多技能" : "Mumbled and learned a bunch of skills"}</h2>
  </div>
  {skills.map((sg) => (
    <div class="skill-block reveal">
      <div class="k">{sg.category}</div>
      <div class="chips">
        {sg.items.map((item) => <span class="chip">{item}</span>)}
      </div>
    </div>
  ))}
</section>

<!-- Honors -->
<section class="section" style="padding-top:0;">
  <div class="reveal">
    <div class="eyebrow">{lang === "zh" ? "工作学习之外" : "Beyond Work and Study"}</div>
    <h2 class="h2">{lang === "zh" ? "关于范诚昊是活人的证明" : "Proof That I'm a Real Person"}</h2>
  </div>
  <div class="honor-card-grid">
    {honors.map((h) => (
      <div class="card reveal">
        <div class="card-art">
          {h.imagePlaceholder ? (
            <img src={h.imagePlaceholder} alt={h.title} />
          ) : (
            <svg viewBox="0 0 400 200" width="100%" height="100%" aria-hidden="true">
              <rect width="400" height="200" fill="#eef3f2"/>
              <circle cx="200" cy="100" r="30" fill="none" stroke="#0E8C82" stroke-width="1.4" opacity=".35"/>
              <circle cx="200" cy="100" r="6" fill="#0E8C82" opacity=".7"/>
              <circle cx="200" cy="70" r="3" fill="#0E8C82" opacity=".5"/>
              <circle cx="230" cy="100" r="3" fill="#0E8C82" opacity=".5"/>
            </svg>
          )}
        </div>
        <div class="card-body">
          <h3>{h.title}</h3>
          <p>{h.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .skill-block {
    margin-top: 38px;
  }
  .skill-block .k {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 14px;
  }

  /* honor cards — same layout & behavior as project cards */
  .honor-card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 54px;
  }
  @media (max-width: 720px) {
    .honor-card-grid {
      grid-template-columns: 1fr;
    }
  }

  .card {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition: 0.3s;
    display: flex;
    flex-direction: column;
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.08);
  }
  .card-art {
    height: 280px;
    position: relative;
    overflow: hidden;
    background: #f2f4f4;
  }
  .card-art img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-body {
    padding: 24px 26px 28px;
  }
  .card h3 {
    font-size: 21px;
    font-weight: 600;
    margin: 16px 0 8px;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .card p {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.55;
  }
</style>
