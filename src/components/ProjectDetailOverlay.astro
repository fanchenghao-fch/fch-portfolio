---
import { projects } from "../data/projects";
import type { Lang } from "../lib/i18n";

const lang = (Astro.locals?.lang ?? "zh") as Lang;

const projectsJSON = JSON.stringify(
  projects.map((p) => ({
    slug: p.slug,
    title: p.title,
    titleEn: p.titleEn,
    role: p.role,
    roleEn: p.roleEn,
    period: p.period,
    periodLabel: p.periodLabel,
    periodLabelEn: p.periodLabelEn,
    tags: p.tags,
    detailOverview: p.detailOverview,
    detailOverviewEn: p.detailOverviewEn,
    detailWork: p.detailWork,
    detailWorkEn: p.detailWorkEn,
    detailOutcome: p.detailOutcome,
    detailOutcomeEn: p.detailOutcomeEn,
    detailSections: p.detailSections,
    images: p.images,
    links: p.links,
  }))
);

const t = {
  zh: {
    close: "关闭",
    myRole: "我的角色",
    period: "时间",
    overview: "项目概述",
    myWork: "我的工作",
    outcome: "产出成果",
    backToProjects: "返回作品集",
  },
  en: {
    close: "Close",
    myRole: "My Role",
    period: "Period",
    overview: "Overview",
    myWork: "My Work",
    outcome: "Outcome",
    backToProjects: "Back to Projects",
  },
}[lang];
---

<div
  class="proj-overlay"
  id="projOverlay"
  aria-hidden="true"
  data-lang={lang}
>
  <div class="proj-modal" id="projModal">
    <!-- close button -->
    <button class="proj-close" id="projClose" aria-label={t.close}>
      <svg viewBox="0 0 24 24" fill="none" stroke="#1D1D1F" stroke-width="2">
        <line x1="6" y1="6" x2="18" y2="18" /><line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </button>

    <!-- art -->
    <div class="proj-art">
      <svg viewBox="0 0 600 240" width="100%" height="100%" preserveAspectRatio="xMidYMid slice">
        <rect width="600" height="240" fill="#eaf2f0" />
        <g stroke="rgba(14,140,130,0.18)" stroke-width="1">
          <line x1="150" y1="0" x2="150" y2="240" /><line x1="300" y1="0" x2="300" y2="240" /><line x1="450" y1="0" x2="450" y2="240" />
          <line x1="0" y1="80" x2="600" y2="80" /><line x1="0" y1="160" x2="600" y2="160" />
        </g>
        <g>
          <circle cx="150" cy="80" r="7" fill="#0E8C82" /><circle cx="300" cy="160" r="9" fill="#0E8C82" />
          <circle cx="450" cy="80" r="7" fill="#0E8C82" /><circle cx="300" cy="80" r="5" fill="#0E8C82" opacity=".6" />
        </g>
        <g stroke="#0E8C82" stroke-width="1.6" opacity=".55">
          <line x1="150" y1="80" x2="300" y2="160" /><line x1="300" y1="160" x2="450" y2="80" />
          <line x1="300" y1="160" x2="300" y2="80" />
        </g>
      </svg>
    </div>

    <!-- body — populated by JS -->
    <div class="proj-body" id="projBody"></div>
  </div>
</div>

<!-- video overlay (z-index above proj-overlay) -->
<div class="video-overlay" id="videoOverlay" aria-hidden="true">
  <div class="video-modal" id="videoModal">
    <button class="video-close" id="videoClose" aria-label="关闭视频">&times;</button>
    <video id="videoPlayer" controls playsinline></video>
  </div>
</div>

<pre id="proj-data" style="display:none;">{projectsJSON}</pre>
<script is:inline>
  var PROJ_DATA = JSON.parse(document.getElementById("proj-data").textContent);

  var overlay = document.getElementById("projOverlay");
  var projBody = document.getElementById("projBody");
  var closeBtn = document.getElementById("projClose");
  var lang = overlay.dataset.lang || "zh";

  var t = {
    zh: { myRole: "我的角色", period: "时间", overview: "项目概述", myWork: "我的工作", outcome: "产出成果", backToProjects: "返回作品集" },
    en: { myRole: "My Role", period: "Period", overview: "Overview", myWork: "My Work", outcome: "Outcome", backToProjects: "Back to Projects" }
  }[lang];

  var currentSlug = null;

  function renderProject(slug) {
    var p = PROJ_DATA.find(function(x) { return x.slug === slug; });
    if (!p) return;

    var isZh = lang === "zh";
    var title = isZh ? p.title : p.titleEn;
    var role = isZh ? p.role : p.roleEn;
    var periodLabel = (isZh ? (p.periodLabel || t.period) : (p.periodLabelEn || t.period));

    var html = "";

    if (p.tags.length) {
      html += '<div>';
      p.tags.forEach(function(tag) { html += '<span class="proj-tag">' + tag + '</span>'; });
      html += '</div>';
    }

    html += '<h1 class="proj-title">' + title + '</h1>';

    html += '<div class="proj-meta">';
    html += '<div><div class="proj-meta-k">' + t.myRole + '</div><div class="proj-meta-v">' + role + '</div></div>';
    html += '<div><div class="proj-meta-k">' + periodLabel + '</div><div class="proj-meta-v">' + p.period + '</div></div>';
    html += '</div>';

    // Custom detailSections or default three-section layout
    if (p.detailSections && p.detailSections.length > 0) {
      p.detailSections.forEach(function(sec) {
        var secTitle = isZh ? sec.title : (sec.titleEn || sec.title);
        if (sec.text) {
          var secText = isZh ? sec.text : (sec.textEn || sec.text);
          html += '<div class="proj-block"><h3>' + secTitle + '</h3><p>' + secText + '</p></div>';
        }
        if (sec.items && sec.items.length > 0) {
          var secItems = isZh ? sec.items : (sec.itemsEn || sec.items);
          html += '<div class="proj-block"><h3>' + secTitle + '</h3><ul>';
          secItems.forEach(function(item) { html += '<li>' + item + '</li>'; });
          html += '</ul></div>';
        }
        if (sec.url) {
          html += '<div class="proj-block"><h3>' + secTitle + '</h3>';
          html += '<a href="' + sec.url + '" class="btn btn-primary" target="_blank" rel="noopener">' + sec.url + ' →</a>';
          html += '</div>';
        }
        if (sec.video) {
          html += '<div class="proj-block"><h3>' + secTitle + '</h3>';
          html += '<button class="btn btn-primary" onclick="openVideoOverlay(\'' + sec.video + '\', ' + (sec.videoWidth || 0) + ', ' + (sec.videoHeight || 0) + ')">▶ 播放视频</button>';
          html += '</div>';
        }
      });
    } else {
      // Default layout
      var overview = isZh ? p.detailOverview : p.detailOverviewEn;
      var work = isZh ? p.detailWork : p.detailWorkEn;
      var outcome = isZh ? p.detailOutcome : p.detailOutcomeEn;

      html += '<div class="proj-block"><h3>' + t.overview + '</h3><p>' + overview + '</p></div>';

      html += '<div class="proj-block"><h3>' + t.myWork + '</h3><ul>';
      work.forEach(function(w) { html += '<li>' + w + '</li>'; });
      html += '</ul></div>';

      html += '<div class="proj-block"><h3>' + t.outcome + '</h3><p>' + outcome + '</p>';
      if (p.images && p.images.length > 0) {
        html += '<div class="proj-gallery">';
        p.images.forEach(function(img) {
          html += '<div class="proj-shot"><img src="' + img + '" alt="" loading="lazy"></div>';
        });
        html += '</div>';
      }
      html += '</div>';
    }

    if (p.links && p.links.length > 0) {
      html += '<div class="proj-links">';
      p.links.forEach(function(lk) {
        var label = isZh ? lk.label : (lk.labelEn || lk.label);
        html += '<a href="' + lk.url + '" class="btn btn-primary" target="_blank" rel="noopener">' + label + ' →</a>';
      });
      html += '<button class="btn btn-ghost" onclick="closeProject()">' + t.backToProjects + '</button>';
      html += '</div>';
    } else {
      html += '<div class="proj-links">';
      html += '<button class="btn btn-ghost" onclick="closeProject()">' + t.backToProjects + '</button>';
      html += '</div>';
    }

    projBody.innerHTML = html;
    projBody.scrollTop = 0;
    currentSlug = slug;
  }

  function openProject(slug) {
    if (overlay.classList.contains("open") && currentSlug === slug) return;

    renderProject(slug);
    overlay.classList.add("open");
    document.body.classList.add("proj-open");
    overlay.setAttribute("aria-hidden", "false");

    var url = "/" + (lang === "en" ? "en/" : "") + "project/" + slug;
    history.pushState({ projectOverlay: slug }, "", url);
  }

  function closeProject() {
    overlay.classList.remove("open");
    document.body.classList.remove("proj-open");
    overlay.setAttribute("aria-hidden", "true");
    currentSlug = null;

    var homeUrl = lang === "en" ? "/en/home" : "/home";
    history.replaceState(null, "", homeUrl + "#projects");
  }

  window.openProject = openProject;
  window.closeProject = closeProject;

  // ── video overlay ──
  var videoOverlay = document.getElementById("videoOverlay");
  var videoPlayer = document.getElementById("videoPlayer");
  var videoCloseBtn = document.getElementById("videoClose");

  function openVideoOverlay(src, vw, vh) {
    videoPlayer.querySelector("source") && videoPlayer.querySelector("source").remove();
    var source = document.createElement("source");
    source.src = src;
    source.type = "video/mp4";
    videoPlayer.appendChild(source);
    videoPlayer.load();
    videoPlayer.style.aspectRatio = vw && vh ? vw + "/" + vh : "auto";
    videoPlayer.style.maxHeight = vh ? Math.min(vh, window.innerHeight * 0.85) + "px" : "85vh";
    videoOverlay.classList.add("open");
    videoOverlay.setAttribute("aria-hidden", "false");
    document.body.classList.add("video-open");
    videoPlayer.play();
  }

  function closeVideoOverlay() {
    videoPlayer.pause();
    videoOverlay.classList.remove("open");
    videoOverlay.setAttribute("aria-hidden", "true");
    document.body.classList.remove("video-open");
  }

  videoCloseBtn.addEventListener("click", closeVideoOverlay);

  videoOverlay.addEventListener("click", function(e) {
    if (e.target === videoOverlay) closeVideoOverlay();
  });

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape" && videoOverlay.classList.contains("open")) {
      closeVideoOverlay();
    }
  });

  closeBtn.addEventListener("click", closeProject);

  overlay.addEventListener("click", function(e) {
    if (e.target === overlay) closeProject();
  });

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape" && overlay.classList.contains("open")) {
      closeProject();
    }
  });

  window.addEventListener("popstate", function(e) {
    var state = e.state;
    if (state && state.projectOverlay) {
      renderProject(state.projectOverlay);
      overlay.classList.add("open");
      document.body.classList.add("proj-open");
      overlay.setAttribute("aria-hidden", "false");
      currentSlug = state.projectOverlay;
    } else if (overlay.classList.contains("open")) {
      overlay.classList.remove("open");
      document.body.classList.remove("proj-open");
      overlay.setAttribute("aria-hidden", "true");
      currentSlug = null;
    }
  });

  document.addEventListener("click", function(e) {
    var card = e.target.closest(".hcard");
    if (!card) return;
    var href = card.getAttribute("href");
    if (!href) return;
    var match = href.match(/\/project\/([^/?#]+)/);
    if (!match) return;

    e.preventDefault();
    openProject(match[1]);
  });
</script>

<style>
  /* ── overlay structure (scoped: targets static HTML only) ── */
  /* Content typography styles live in global.css (they target JS-injected HTML) */
  .proj-overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 48px 20px;
    overflow-y: auto;
    background: rgba(20, 24, 26, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .proj-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .proj-modal {
    position: relative;
    width: 100%;
    max-width: 780px;
    max-height: calc(100vh - 96px);
    background: #fff;
    border-radius: 26px;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.3);
    animation: projRise 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
  }
  @keyframes projRise {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: none; }
  }

  .proj-close {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 5;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: 0.2s;
  }
  .proj-close:hover {
    background: #fff;
    transform: scale(1.05);
  }
  .proj-close svg { width: 16px; height: 16px; }

  .proj-art {
    height: 240px;
    background: #eaf2f0;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  body.proj-open { overflow: hidden; }
  body.video-open { overflow: hidden; }

  /* ── video overlay ── */
  .video-overlay {
    position: fixed;
    inset: 0;
    z-index: 110;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
    background: rgba(0, 0, 0, 0.78);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .video-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .video-modal {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    animation: projRise 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .video-close {
    position: absolute;
    top: -40px;
    right: 0;
    z-index: 5;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    color: #fff;
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 0.2s;
  }
  .video-close:hover {
    background: rgba(255, 255, 255, 0.35);
  }

  .video-modal video {
    border-radius: 14px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
    max-width: 90vw;
    max-height: 85vh;
    background: #000;
  }

  @media (max-width: 640px) {
    .proj-overlay { padding: 20px 12px; }
    .proj-modal { max-height: calc(100vh - 40px); }
    .proj-art { height: 180px; }
    .video-overlay { padding: 16px; }
    .video-close { top: -36px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .proj-overlay, .proj-modal, .video-overlay, .video-modal {
      transition: none;
      animation: none;
    }
  }
</style>
