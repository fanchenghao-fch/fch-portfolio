---
import { projects } from "../data/projects";
import type { Lang } from "../lib/i18n";

const lang = (Astro.locals?.lang ?? "zh") as Lang;

const projectsJSON = JSON.stringify(
  projects.map((p) => ({
    slug: p.slug,
    title: p.title,
    titleEn: p.titleEn,
    role: p.role,
    roleEn: p.roleEn,
    period: p.period,
    tags: p.tags,
    detailOverview: p.detailOverview,
    detailOverviewEn: p.detailOverviewEn,
    detailWork: p.detailWork,
    detailWorkEn: p.detailWorkEn,
    detailOutcome: p.detailOutcome,
    detailOutcomeEn: p.detailOutcomeEn,
    images: p.images,
    links: p.links,
  }))
);

const t = {
  zh: {
    close: "关闭",
    myRole: "我的角色",
    period: "时间",
    overview: "项目概述",
    myWork: "我的工作",
    outcome: "产出成果",
    backToProjects: "返回作品集",
  },
  en: {
    close: "Close",
    myRole: "My Role",
    period: "Period",
    overview: "Overview",
    myWork: "My Work",
    outcome: "Outcome",
    backToProjects: "Back to Projects",
  },
}[lang];
---

<div
  class="proj-overlay"
  id="projOverlay"
  aria-hidden="true"
  data-lang={lang}
>
  <div class="proj-modal" id="projModal">
    <!-- close button -->
    <button class="proj-close" id="projClose" aria-label={t.close}>
      <svg viewBox="0 0 24 24" fill="none" stroke="#1D1D1F" stroke-width="2">
        <line x1="6" y1="6" x2="18" y2="18" /><line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </button>

    <!-- art -->
    <div class="proj-art">
      <svg viewBox="0 0 600 240" width="100%" height="100%" preserveAspectRatio="xMidYMid slice">
        <rect width="600" height="240" fill="#eaf2f0" />
        <g stroke="rgba(14,140,130,0.18)" stroke-width="1">
          <line x1="150" y1="0" x2="150" y2="240" /><line x1="300" y1="0" x2="300" y2="240" /><line x1="450" y1="0" x2="450" y2="240" />
          <line x1="0" y1="80" x2="600" y2="80" /><line x1="0" y1="160" x2="600" y2="160" />
        </g>
        <g>
          <circle cx="150" cy="80" r="7" fill="#0E8C82" /><circle cx="300" cy="160" r="9" fill="#0E8C82" />
          <circle cx="450" cy="80" r="7" fill="#0E8C82" /><circle cx="300" cy="80" r="5" fill="#0E8C82" opacity=".6" />
        </g>
        <g stroke="#0E8C82" stroke-width="1.6" opacity=".55">
          <line x1="150" y1="80" x2="300" y2="160" /><line x1="300" y1="160" x2="450" y2="80" />
          <line x1="300" y1="160" x2="300" y2="80" />
        </g>
      </svg>
    </div>

    <!-- body — populated by JS -->
    <div class="proj-body" id="projBody"></div>
  </div>
</div>

<script>
  const PROJ_DATA = {projectsJSON};

  const overlay = document.getElementById("projOverlay")!;
  const modal = document.getElementById("projModal")!;
  const body = document.getElementById("projBody")!;
  const closeBtn = document.getElementById("projClose")!;
  const lang = overlay.dataset.lang || "zh";

  const t = {
    zh: { myRole: "我的角色", period: "时间", overview: "项目概述", myWork: "我的工作", outcome: "产出成果", backToProjects: "返回作品集" },
    en: { myRole: "My Role", period: "Period", overview: "Overview", myWork: "My Work", outcome: "Outcome", backToProjects: "Back to Projects" },
  }[lang]!;

  let currentSlug: string | null = null;

  function renderProject(slug: string) {
    const p = PROJ_DATA.find((x: any) => x.slug === slug);
    if (!p) return;

    const isZh = lang === "zh";
    const title = isZh ? p.title : p.titleEn;
    const role = isZh ? p.role : p.roleEn;
    const overview = isZh ? p.detailOverview : p.detailOverviewEn;
    const work: string[] = isZh ? p.detailWork : p.detailWorkEn;
    const outcome = isZh ? p.detailOutcome : p.detailOutcomeEn;

    let html = "";

    // tags
    if (p.tags.length) {
      html += '<div>';
      p.tags.forEach((tag: string) => { html += `<span class="proj-tag">${tag}</span>`; });
      html += '</div>';
    }

    // title
    html += `<h1 class="proj-title">${title}</h1>`;

    // meta
    html += '<div class="proj-meta">';
    html += `<div><div class="proj-meta-k">${t.myRole}</div><div class="proj-meta-v">${role}</div></div>`;
    html += `<div><div class="proj-meta-k">${t.period}</div><div class="proj-meta-v">${p.period}</div></div>`;
    html += '</div>';

    // overview
    html += `<div class="proj-block"><h3>${t.overview}</h3><p>${overview}</p></div>`;

    // my work
    html += `<div class="proj-block"><h3>${t.myWork}</h3><ul>`;
    work.forEach((w: string) => { html += `<li>${w}</li>`; });
    html += '</ul></div>';

    // outcome
    html += `<div class="proj-block"><h3>${t.outcome}</h3><p>${outcome}</p>`;
    if (p.images && p.images.length > 0) {
      html += '<div class="proj-gallery">';
      p.images.forEach((img: string) => {
        html += `<div class="proj-shot"><img src="${img}" alt="" loading="lazy" /></div>`;
      });
      html += '</div>';
    }
    html += '</div>';

    // links
    if (p.links && p.links.length > 0) {
      html += '<div class="proj-links">';
      p.links.forEach((lk: any) => {
        const label = isZh ? lk.label : (lk.labelEn || lk.label);
        html += `<a href="${lk.url}" class="proj-lk proj-lk-primary" target="_blank" rel="noopener">${label} →</a>`;
      });
      html += `<button class="proj-lk proj-lk-ghost" onclick="closeProject()">${t.backToProjects}</button>`;
      html += '</div>';
    } else {
      html += '<div class="proj-links">';
      html += `<button class="proj-lk proj-lk-ghost" onclick="closeProject()">${t.backToProjects}</button>`;
      html += '</div>';
    }

    body.innerHTML = html;
    body.scrollTop = 0;
    currentSlug = slug;
  }

  function openProject(slug: string) {
    if (overlay.classList.contains("open") && currentSlug === slug) return;

    renderProject(slug);
    overlay.classList.add("open");
    document.body.classList.add("proj-open");
    overlay.setAttribute("aria-hidden", "false");

    // URL sync
    const url = `/${lang === "en" ? "en/" : ""}project/${slug}`;
    history.pushState({ projectOverlay: slug }, "", url);
  }

  function closeProject() {
    overlay.classList.remove("open");
    document.body.classList.remove("proj-open");
    overlay.setAttribute("aria-hidden", "true");
    currentSlug = null;

    // URL sync — replace state so back button doesn't re-open
    const homeUrl = lang === "en" ? "/en/home" : "/home";
    history.replaceState(null, "", `${homeUrl}#projects`);
  }

  // Expose globally
  (window as any).openProject = openProject;
  (window as any).closeProject = closeProject;

  // ── Close triggers ──
  closeBtn.addEventListener("click", closeProject);

  // Click backdrop (not modal)
  overlay.addEventListener("click", (e) => {
    if (e.target === overlay) closeProject();
  });

  // ESC key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && overlay.classList.contains("open")) {
      closeProject();
    }
  });

  // ── Browser back/forward ──
  window.addEventListener("popstate", (e) => {
    const state = e.state as { projectOverlay?: string } | null;
    if (state?.projectOverlay) {
      // forward: re-open overlay
      renderProject(state.projectOverlay);
      overlay.classList.add("open");
      document.body.classList.add("proj-open");
      overlay.setAttribute("aria-hidden", "false");
      currentSlug = state.projectOverlay;
    } else if (overlay.classList.contains("open")) {
      // back: close overlay without touching history
      overlay.classList.remove("open");
      document.body.classList.remove("proj-open");
      overlay.setAttribute("aria-hidden", "true");
      currentSlug = null;
    }
  });

  // ── Intercept project card clicks ──
  document.addEventListener("click", (e) => {
    const target = (e.target as HTMLElement).closest(".hcard") as HTMLAnchorElement | null;
    if (!target) return;
    // Only intercept if it links to a project detail page
    const href = target.getAttribute("href");
    if (!href) return;
    const match = href.match(/\/project\/([^/?#]+)/);
    if (!match) return;

    e.preventDefault();
    openProject(match[1]);
  });
</script>

<style>
  /* ── overlay ── */
  .proj-overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 48px 20px;
    overflow-y: auto;
    background: rgba(20, 24, 26, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .proj-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .proj-modal {
    position: relative;
    width: 100%;
    max-width: 780px;
    background: #fff;
    border-radius: 26px;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.3);
    animation: projRise 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes projRise {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: none; }
  }

  .proj-close {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 5;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: 0.2s;
  }
  .proj-close:hover {
    background: #fff;
    transform: scale(1.05);
  }
  .proj-close svg { width: 16px; height: 16px; }

  .proj-art {
    height: 240px;
    background: #eaf2f0;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .proj-body {
    padding: 38px 44px 44px;
  }

  .proj-tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    color: #0A6E66;
    background: #E8F4F2;
    border-radius: 980px;
    padding: 6px 14px;
    letter-spacing: 0.02em;
    margin-right: 8px;
    margin-bottom: 8px;
  }

  .proj-title {
    font-size: clamp(26px, 4vw, 36px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 18px 0 0;
    color: #1D1D1F;
  }

  .proj-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    margin-top: 24px;
    padding-bottom: 26px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }
  .proj-meta-k {
    font-size: 12px;
    color: #9a9aa0;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .proj-meta-v {
    font-size: 15px;
    color: #1D1D1F;
    margin-top: 6px;
    font-weight: 500;
  }

  .proj-block { margin-top: 32px; }
  .proj-block h3 {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0A6E66;
    margin-bottom: 14px;
  }
  .proj-block p {
    font-size: 16px;
    line-height: 1.7;
    color: #333;
  }
  .proj-block ul {
    list-style: none;
    margin-top: 6px;
  }
  .proj-block li {
    font-size: 16px;
    line-height: 1.7;
    color: #333;
    padding-left: 22px;
    position: relative;
  }
  .proj-block li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 11px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #0E8C82;
  }

  .proj-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 16px;
  }
  .proj-shot {
    aspect-ratio: 4/3;
    background: #eef3f2;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #a9b8b5;
    font-size: 12px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }
  .proj-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .proj-links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 34px;
  }
  .proj-lk {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 46px;
    padding: 0 22px;
    border-radius: 980px;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: 0.25s;
    text-decoration: none;
    font-family: inherit;
  }
  .proj-lk-primary {
    background: #0E8C82;
    color: #fff;
    border: none;
  }
  .proj-lk-primary:hover {
    background: #0A6E66;
  }
  .proj-lk-ghost {
    border: 1px solid rgba(0, 0, 0, 0.1);
    color: #1D1D1F;
    background: transparent;
  }
  .proj-lk-ghost:hover {
    background: #FBFBFD;
  }

  body.proj-open { overflow: hidden; }

  @media (max-width: 640px) {
    .proj-overlay { padding: 20px 12px; }
    .proj-body { padding: 30px 24px 34px; }
    .proj-gallery { grid-template-columns: repeat(2, 1fr); }
    .proj-art { height: 180px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .proj-overlay, .proj-modal {
      transition: none;
      animation: none;
    }
  }
</style>
