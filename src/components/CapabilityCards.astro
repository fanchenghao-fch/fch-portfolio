---
import type { Lang } from "../lib/i18n";
import { profileContent } from "../data/profile";

const lang = (Astro.locals?.lang ?? "zh") as Lang;
const caps = profileContent[lang].capabilities;
---

<div class="cap-grid">
  {caps.map((cap, i) => (
    <div class="cap reveal">
      <div class="num">{cap.num}</div>
      <h3>{cap.title}</h3>
      <p>{cap.desc}</p>
    </div>
  ))}
</div>

<style>
  .cap-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 54px;
  }
  .cap {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 30px 28px;
    transition: 0.3s;
  }
  .cap:hover {
    transform: translateY(-4px);
    border-color: rgba(14, 140, 130, 0.35);
  }
  .cap .num {
    font-size: 13px;
    font-weight: 600;
    color: var(--teal-deep);
    letter-spacing: 0.08em;
  }
  .cap h3 {
    font-size: 21px;
    font-weight: 600;
    margin: 14px 0 10px;
    letter-spacing: -0.02em;
  }
  .cap p {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.6;
  }
  @media (max-width: 820px) {
    .cap-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
