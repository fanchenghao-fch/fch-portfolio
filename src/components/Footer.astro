---
import { profileContent } from "../data/profile";
import type { Lang } from "../lib/i18n";

const lang = (Astro.locals?.lang ?? "zh") as Lang;
const t = profileContent[lang];
---

<footer class="foot" id="contact">
  <div class="foot-in">
    <div class="reveal">
      <div class="eyebrow">{lang === "zh" ? "联系" : "Contact"}</div>
      <h2>{lang === "zh" ? "欢迎交流～" : "Let's talk!"}</h2>
    </div>
    <div class="foot-grid">
      <div><div class="k">Email</div><div class="v">{t.contact.email}</div></div>
      <div><div class="k">Phone</div><div class="v">{t.contact.phone}</div></div>
      <div><div class="k">WeChat</div><div class="v">{t.contact.wechat}</div></div>
      <div>
        <div class="k">{lang === "zh" ? "简历" : "Resume"}</div>
        <div class="v"><a href="/resume.pdf" style="color:#5ec9bd;">{t.contact.resumeText}</a></div>
      </div>
    </div>
    <div class="foot-bottom">
      <span>{t.footer.copyright}</span>
    </div>
  </div>
</footer>

<style>
  .foot {
    background: var(--graphite);
    color: #f5f5f7;
  }
  .foot-in {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(64px, 9vw, 108px) 22px;
  }
  .foot h2 {
    font-size: clamp(30px, 4.6vw, 48px);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: #fff;
  }
  .foot-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
    margin-top: 48px;
  }
  .foot-grid .k {
    font-size: 12px;
    color: #8e8e93;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .foot-grid .v {
    font-size: 16px;
    color: #f5f5f7;
    margin-top: 8px;
    word-break: break-all;
  }
  .foot-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    margin-top: 54px;
    padding-top: 26px;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 13px;
    color: #8e8e93;
  }
  @media (max-width: 720px) {
    .foot-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
