---
import type { Project } from "../lib/types";
import type { Lang } from "../lib/i18n";

interface Props {
  project: Project;
  lang: Lang;
}

const { project, lang } = Astro.props;
const title = lang === "zh" ? project.title : project.titleEn;
const summary = lang === "zh" ? project.summary : project.summaryEn;
const tags = project.tags;
const moreText = lang === "zh" ? "查看详情 →" : "View Details →";
---

<a href={`/project/${project.slug}`} class="card reveal">
  <div class="card-art">
    <svg viewBox="0 0 400 200" width="100%" height="100%">
      <rect width="400" height="200" fill="#eef3f2"/>
      <circle cx="120" cy="100" r="5" fill="#0E8C82"/>
      <circle cx="220" cy="70" r="5" fill="#0E8C82"/>
      <circle cx="300" cy="130" r="5" fill="#0E8C82"/>
      <line x1="120" y1="100" x2="220" y2="70" stroke="#0E8C82" stroke-width="1.4" opacity=".5"/>
      <line x1="220" y1="70" x2="300" y2="130" stroke="#0E8C82" stroke-width="1.4" opacity=".5"/>
    </svg>
  </div>
  <div class="card-body">
    <div>
      {tags.map((t) => <span class="tag">{t}</span>)}
    </div>
    <h3>{title}</h3>
    <p>{summary}</p>
    <span class="more">{moreText}</span>
  </div>
</a>

<style>
  .card {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition: 0.3s;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.08);
  }
  .card-art {
    height: 168px;
    position: relative;
    overflow: hidden;
    background: #f2f4f4;
  }
  .card-body {
    padding: 24px 26px 28px;
  }
  .card h3 {
    font-size: 21px;
    font-weight: 600;
    margin: 16px 0 8px;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .card p {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.55;
  }
  .card .more {
    font-size: 14px;
    color: var(--teal-deep);
    font-weight: 500;
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
</style>
