---
import type { Project } from "../lib/types";
import type { Lang } from "../lib/i18n";

interface Props {
  project: Project;
  lang: Lang;
  index: number;
}

const { project, lang, index } = Astro.props;
const title = lang === "zh" ? project.title : project.titleEn;
const summary = lang === "zh" ? project.summary : project.summaryEn;
const tags = project.tags;
const moreText = lang === "zh" ? "查看详情 →" : "View Details →";
const idx = String(index).padStart(2, "0");
---

<a href={`/project/${project.slug}`} class="hcard reveal">
  <span class="idx">{idx}</span>
  <div class="hcard-art">
    <svg viewBox="0 0 400 200" width="100%" height="100%">
      <rect width="400" height="200" fill="#eef3f2"/>
      <circle cx="120" cy="100" r="5" fill="#0E8C82"/>
      <circle cx="220" cy="70" r="5" fill="#0E8C82"/>
      <circle cx="300" cy="130" r="5" fill="#0E8C82"/>
      <line x1="120" y1="100" x2="220" y2="70" stroke="#0E8C82" stroke-width="1.4" opacity=".5"/>
      <line x1="220" y1="70" x2="300" y2="130" stroke="#0E8C82" stroke-width="1.4" opacity=".5"/>
    </svg>
  </div>
  <div class="hcard-body">
    <div>
      {tags.map((t) => <span class="tag">{t}</span>)}
    </div>
    <h3>{title}</h3>
    <p>{summary}</p>
    <span class="more">{moreText}</span>
  </div>
</a>

<style>
  .hcard {
    scroll-snap-align: start;
    flex: 0 0 clamp(280px, 78vw, 340px);
    height: 430px;
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  }
  .hcard:hover {
    transform: translateY(-5px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.08);
    border-color: rgba(14, 140, 130, 0.4);
  }
  .hcard .idx {
    position: absolute;
    top: 14px;
    left: 16px;
    z-index: 2;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--teal-deep);
    opacity: 0.5;
  }
  .hcard-art {
    flex: 1 1 auto;
    min-height: 150px;
    background: #f2f4f4;
    position: relative;
    overflow: hidden;
  }
  .hcard-art svg {
    width: 100%;
    height: 100%;
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hcard:hover .hcard-art svg {
    transform: scale(1.05);
  }
  .hcard-art::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 42%, rgba(14, 140, 130, 0.12), transparent 62%);
    opacity: 0;
    transition: opacity 0.45s;
    pointer-events: none;
  }
  .hcard:hover .hcard-art::after {
    opacity: 1;
  }
  .hcard-body {
    padding: 20px 22px 24px;
  }
  .hcard-body h3 {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin: 11px 0 7px;
  }
  .hcard-body p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hcard .more {
    margin-top: 12px;
    font-size: 13px;
    font-weight: 500;
    color: var(--teal-deep);
    display: inline-flex;
    gap: 5px;
    align-items: center;
  }
  @media (prefers-reduced-motion: reduce) {
    .hcard,
    .hcard-art svg,
    .hcard-art::after {
      transition: none;
    }
  }
</style>
