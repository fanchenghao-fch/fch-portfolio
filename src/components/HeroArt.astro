<svg viewBox="0 0 400 400" width="100%" height="100%" aria-hidden="true">
  <g>
    <line class="grid-line" x1="60" y1="0" x2="60" y2="400"/>
    <line class="grid-line" x1="140" y1="0" x2="140" y2="400"/>
    <line class="grid-line" x1="220" y1="0" x2="220" y2="400"/>
    <line class="grid-line" x1="300" y1="0" x2="300" y2="400"/>
    <line class="grid-line" x1="0" y1="80" x2="400" y2="80"/>
    <line class="grid-line" x1="0" y1="160" x2="400" y2="160"/>
    <line class="grid-line" x1="0" y1="240" x2="400" y2="240"/>
    <line class="grid-line" x1="0" y1="320" x2="400" y2="320"/>
  </g>
  <g>
    <line class="edge" x1="60" y1="80" x2="220" y2="160"/>
    <line class="edge" x1="220" y1="160" x2="300" y2="80" style="animation-delay:.3s"/>
    <line class="edge" x1="220" y1="160" x2="140" y2="320" style="animation-delay:.5s"/>
    <line class="edge" x1="140" y1="320" x2="300" y2="240" style="animation-delay:.7s"/>
    <line class="edge" x1="300" y1="240" x2="300" y2="80" style="animation-delay:.9s"/>
  </g>
  <g>
    <circle class="node" cx="60" cy="80" r="6"/><circle class="node-ring" cx="60" cy="80" r="6" style="transform-origin:60px 80px"/>
    <circle class="node" cx="220" cy="160" r="8"/><circle class="node-ring" cx="220" cy="160" r="8" style="transform-origin:220px 160px;animation-delay:.6s"/>
    <circle class="node" cx="300" cy="80" r="6"/><circle class="node-ring" cx="300" cy="80" r="6" style="transform-origin:300px 80px;animation-delay:1.1s"/>
    <circle class="node" cx="140" cy="320" r="7"/><circle class="node-ring" cx="140" cy="320" r="7" style="transform-origin:140px 320px;animation-delay:1.6s"/>
    <circle class="node" cx="300" cy="240" r="6"/><circle class="node-ring" cx="300" cy="240" r="6" style="transform-origin:300px 240px;animation-delay:2.1s"/>
  </g>
</svg>

<style>
  .grid-line {
    stroke: rgba(14, 140, 130, 0.16);
    stroke-width: 1;
  }
  .node {
    fill: var(--teal);
  }
  .node-ring {
    fill: none;
    stroke: var(--teal);
    stroke-width: 1.4;
    opacity: 0.5;
    animation: pulse 3.4s ease-in-out infinite;
  }
  .edge {
    stroke: var(--teal);
    stroke-width: 1.4;
    opacity: 0.55;
    stroke-dasharray: 160;
    stroke-dashoffset: 160;
    animation: draw 2.2s ease forwards;
  }
  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.5);
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .node-ring,
    .edge {
      animation: none;
      stroke-dashoffset: 0;
    }
  }
</style>
