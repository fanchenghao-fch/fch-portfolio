---
import type { Lang } from "../lib/i18n";

const lang = (Astro.locals?.lang ?? "zh") as Lang;

const t = {
  zh: {
    title: "范诚昊 · 数字分身",
    subtitle: "基于真实经历作答 · 带引用",
    welcome: "你好，我是范诚昊的数字分身。关于他的 <b>AI 项目、城市规划经历、技能与作品</b>，都可以直接问我。",
    suggestLabel: "你可以这样问",
    placeholder: "问问关于范诚昊的任何事…",
    disclaimer: "仅基于真实语料作答，不编造 · 与职业无关的问题会礼貌婉拒",
    close: "关闭",
    suggestions: [
      "他做过哪些 AI 项目？",
      "他的城市规划背景，怎么帮到做产品？",
      "他自用的 AI 工具库有哪些？",
      "他在此芯科技具体做了什么？",
    ],
  },
  en: {
    title: "Digital Twin · Fan Chenghao",
    subtitle: "Answers based on real experience · with citations",
    welcome: "Hi, I'm Fan Chenghao's digital twin. Ask me anything about his <b>AI projects, urban planning experience, skills, and work</b>.",
    suggestLabel: "Try asking",
    placeholder: "Ask anything about Fan Chenghao...",
    disclaimer: "Based on real data only, no fabrication. Unrelated questions will be politely declined.",
    close: "Close",
    suggestions: [
      "What AI projects has he built?",
      "How does his urban planning background help in product management?",
      "What AI tools does he use?",
      "What did he do at CIX Technology?",
    ],
  },
}[lang];
---

<div class="rag-overlay" id="ragOverlay" aria-hidden="true">
  <div class="rag-panel" id="ragPanel">
    <!-- Header -->
    <div class="rag-head">
      <div class="rag-av">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="2.4" fill="#0E8C82" />
          <circle cx="18" cy="9" r="2.4" fill="#0E8C82" />
          <circle cx="10" cy="18" r="2.4" fill="#0E8C82" />
          <line x1="6" y1="6" x2="18" y2="9" stroke="#0E8C82" stroke-width="1.4" />
          <line x1="18" y1="9" x2="10" y2="18" stroke="#0E8C82" stroke-width="1.4" />
        </svg>
      </div>
      <div class="rag-t">
        <div class="rag-n">{t.title}</div>
        <div class="rag-s">{t.subtitle}</div>
      </div>
      <button class="rag-x" id="ragClose" aria-label={t.close}>
        <svg viewBox="0 0 24 24" fill="none" stroke="#1D1D1F" stroke-width="2">
          <line x1="6" y1="6" x2="18" y2="18" /><line x1="18" y1="6" x2="6" y2="18" />
        </svg>
      </button>
    </div>

    <!-- Thread -->
    <div class="rag-thread" id="ragThread">
      <div class="rag-welcome" id="ragWelcome">{t.welcome}</div>
      <div class="rag-suggest" id="ragSuggest">
        <div class="rag-lbl">{t.suggestLabel}</div>
        <div class="rag-chips">
          {t.suggestions.map((s) => (
            <button class="rag-chip" data-question={s}>{s}</button>
          ))}
        </div>
      </div>
    </div>

    <!-- Composer -->
    <div class="rag-composer">
      <div class="rag-box">
        <textarea
          id="ragInput"
          rows="1"
          placeholder={t.placeholder}
        ></textarea>
        <button class="rag-send" id="ragSendBtn" aria-label="Send">
          <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="19" x2="12" y2="5" /><polyline points="6 11 12 5 18 11" />
          </svg>
        </button>
      </div>
      <div class="rag-disc">{t.disclaimer}</div>
    </div>
  </div>
</div>

<script>
  const ragThread = document.getElementById("ragThread")!;
  const ragInput = document.getElementById("ragInput") as HTMLTextAreaElement;
  const ragSendBtn = document.getElementById("ragSendBtn")!;
  const ragOverlay = document.getElementById("ragOverlay")!;

  let ragHistory: { role: "user" | "assistant"; content: string }[] = [];

  function ragHideSuggest() {
    document.getElementById("ragWelcome")?.remove();
    document.getElementById("ragSuggest")?.remove();
  }

  function ragAddMe(text: string) {
    const d = document.createElement("div");
    d.className = "rag-msg me";
    d.innerHTML = '<div class="rag-bubble"></div>';
    d.querySelector(".rag-bubble")!.textContent = text;
    ragThread.appendChild(d);
    ragThread.scrollTop = ragThread.scrollHeight;
  }

  function ragAddBot(answer: string, cited?: string[]) {
    const d = document.createElement("div");
    d.className = "rag-msg bot";
    d.innerHTML = `<div class="rag-bubble">${answer.replace(/\n/g, "<br>")}</div>`;
    if (cited && cited.length > 0) {
      const refs = document.createElement("div");
      refs.className = "rag-refs";
      cited.forEach((c) => {
        const ref = document.createElement("span");
        ref.className = "rag-ref-tag";
        ref.textContent = c;
        refs.appendChild(ref);
      });
      d.appendChild(refs);
    }
    ragThread.appendChild(d);
    ragThread.scrollTop = ragThread.scrollHeight;
  }

  function ragSetLoading(loading: boolean) {
    ragSendBtn.disabled = loading;
    ragInput.disabled = loading;
    if (loading) {
      const d = document.createElement("div");
      d.className = "rag-msg bot";
      d.id = "rag-loading";
      d.innerHTML = '<div class="rag-bubble" style="color:var(--muted)">...</div>';
      ragThread.appendChild(d);
      ragThread.scrollTop = ragThread.scrollHeight;
    } else {
      document.getElementById("rag-loading")?.remove();
    }
  }

  async function ragAsk(question: string) {
    ragHideSuggest();
    ragAddMe(question);
    ragHistory.push({ role: "user", content: question });
    ragSetLoading(true);

    try {
      const resp = await fetch("/api/rag", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ question, history: ragHistory.slice(-6) }),
      });

      ragSetLoading(false);
      const data = await resp.json();

      if (resp.ok && data.answer) {
        ragAddBot(data.answer, data.citedProjects);
        ragHistory.push({ role: "assistant", content: data.answer });
      } else {
        ragAddBot(data.error || "抱歉，暂时无法回答。请稍后再试。");
      }
    } catch {
      ragSetLoading(false);
      ragAddBot("网络错误，请稍后再试。");
    }
  }

  function ragSend() {
    const v = ragInput.value.trim();
    if (!v) return;
    ragInput.value = "";
    ragGrow(ragInput);
    ragAsk(v);
  }

  function ragGrow(el: HTMLTextAreaElement) {
    el.style.height = "auto";
    el.style.height = Math.min(el.scrollHeight, 120) + "px";
  }

  // ── Open / Close ──
  function openRAG() {
    ragOverlay.classList.add("open");
    document.body.classList.add("rag-open");
    ragOverlay.setAttribute("aria-hidden", "false");
    setTimeout(() => ragInput.focus(), 420);
  }
  function closeRAG() {
    ragOverlay.classList.remove("open");
    document.body.classList.remove("rag-open");
    ragOverlay.setAttribute("aria-hidden", "true");
  }

  // Attach global openRAG / closeRAG for button onclick
  (window as any).openRAG = openRAG;
  (window as any).closeRAG = closeRAG;

  // Event listeners
  document.getElementById("ragClose")!.addEventListener("click", closeRAG);
  ragOverlay.addEventListener("click", (e) => {
    if (e.target === ragOverlay) closeRAG();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && ragOverlay.classList.contains("open")) closeRAG();
  });

  ragSendBtn.addEventListener("click", ragSend);
  ragInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      ragSend();
    }
  });
  ragInput.addEventListener("input", () => ragGrow(ragInput));

  // Suggestion chips
  document.querySelectorAll(".rag-chip").forEach((chip) => {
    chip.addEventListener("click", () => {
      const q = (chip as HTMLElement).dataset.question;
      if (q) ragAsk(q);
    });
  });
</script>

<style>
  /* ── RAG overlay ── */
  .rag-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    justify-content: flex-end;
    background: rgba(20, 24, 26, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .rag-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }
  .rag-panel {
    width: 100%;
    max-width: 460px;
    background: var(--white);
    min-height: 100vh;
    max-height: 100vh;
    display: flex;
    flex-direction: column;
    box-shadow: -20px 0 60px rgba(0, 0, 0, 0.18);
    transform: translateX(40px);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.35s ease;
  }
  .rag-overlay.open .rag-panel {
    transform: none;
    opacity: 1;
  }
  .rag-head {
    padding: 18px 22px;
    border-bottom: 1px solid var(--line);
    display: flex;
    align-items: center;
    gap: 13px;
    flex-shrink: 0;
  }
  .rag-av {
    width: 42px;
    height: 42px;
    border-radius: 13px;
    background: var(--teal-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .rag-av svg {
    width: 24px;
    height: 24px;
  }
  .rag-t {
    flex: 1;
  }
  .rag-n {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .rag-s {
    font-size: 12.5px;
    color: var(--muted);
    margin-top: 2px;
  }
  .rag-x {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: 0.2s;
    background: transparent;
    color: var(--ink);
  }
  .rag-x:hover {
    background: var(--paper);
  }
  .rag-x svg {
    width: 15px;
    height: 15px;
  }
  .rag-thread {
    flex: 1;
    overflow-y: auto;
    padding: 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .rag-welcome {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.6;
  }
  .rag-welcome b {
    color: var(--ink);
    font-weight: 600;
  }
  .rag-lbl {
    font-size: 12px;
    color: #9a9aa0;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 6px 0 12px;
  }
  .rag-chips {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .rag-chip {
    text-align: left;
    font-size: 14.5px;
    color: #333;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 13px 16px;
    cursor: pointer;
    transition: 0.2s;
    font-family: inherit;
    line-height: 1.4;
  }
  .rag-chip:hover {
    border-color: var(--teal);
    background: #fff;
    color: var(--teal-deep);
  }
  .rag-msg {
    display: flex;
    flex-direction: column;
    max-width: 86%;
    animation: ragFadeUp 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes ragFadeUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .rag-msg.me {
    align-self: flex-end;
    align-items: flex-end;
  }
  .rag-bubble {
    font-size: 15px;
    line-height: 1.6;
    padding: 12px 16px;
    border-radius: 18px;
    word-break: break-word;
  }
  .rag-msg.me .rag-bubble {
    background: var(--teal);
    color: #fff;
    border-bottom-right-radius: 6px;
  }
  .rag-msg.bot .rag-bubble {
    background: var(--paper);
    color: var(--ink);
    border: 1px solid var(--line);
    border-bottom-left-radius: 6px;
  }
  .rag-refs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }
  .rag-ref-tag {
    font-size: 12px;
    color: var(--teal-deep);
    background: var(--teal-soft);
    border: 1px solid transparent;
    border-radius: 980px;
    padding: 5px 13px;
    cursor: default;
    transition: 0.2s;
  }
  .rag-ref-tag:hover {
    border-color: var(--teal);
    background: #fff;
    transform: translateY(-1px);
  }
  .rag-composer {
    padding: 14px 18px 20px;
    border-top: 1px solid var(--line);
    flex-shrink: 0;
  }
  .rag-box {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 8px 8px 8px 16px;
    background: #fff;
    transition: 0.2s;
  }
  .rag-box:focus-within {
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(14, 140, 130, 0.12);
  }
  .rag-box textarea {
    flex: 1;
    border: none;
    outline: none;
    resize: none;
    font-family: inherit;
    font-size: 15px;
    line-height: 1.5;
    max-height: 120px;
    color: var(--ink);
    background: transparent;
    padding: 7px 0;
  }
  .rag-send {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: none;
    background: var(--teal);
    cursor: pointer;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 0.2s;
  }
  .rag-send:hover {
    background: var(--teal-deep);
  }
  .rag-send:disabled {
    background: #c9d6d4;
    cursor: not-allowed;
  }
  .rag-send svg {
    width: 18px;
    height: 18px;
  }
  .rag-disc {
    font-size: 11.5px;
    color: #a9a9af;
    text-align: center;
    margin-top: 11px;
    line-height: 1.5;
  }
  body.rag-open {
    overflow: hidden;
  }
  @media (max-width: 520px) {
    .rag-panel {
      max-width: 100vw;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .rag-overlay,
    .rag-panel,
    .rag-msg {
      transition: none;
      animation: none;
    }
  }
</style>
